# Server
NODE_ENV=development
PORT=5000

# Frontend origins. Both Nuxt frontends commonly run on localhost during dev.
# Use comma-separated values if you need more than one allowed origin.
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# JWT
# Use a long random value in real projects. Do not commit your real secret.
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=1d

# Password hashing
BCRYPT_SALT_ROUNDS=12

# Seed account. Keep real seed values in global/.env only.
SEED_SUPER_ADMIN_EMAIL=admin@example.com
SEED_SUPER_ADMIN_PASSWORD=replace_this_with_a_secure_password

# MySQL + Prisma database
# This matches your Aiven MySQL settings:
# Host: mysql-39c4cc2d-haroonzahid644-be2b.k.aivencloud.com
# Port: 12673
# User: avnadmin
# SSL mode: REQUIRED
#
# Replace YOUR_AIVEN_PASSWORD with your real Aiven MySQL password.
# Replace defaultdb if your Aiven database/schema name is different.
# If your password has special characters like @, #, :, /, or spaces,
# URL-encode it before placing it in this connection string.
#
# Basic SSL connection:
DATABASE_URL="mysql://avnadmin:YOUR_AIVEN_PASSWORD@mysql-39c4cc2d-haroonzahid644-be2b.k.aivencloud.com:12673/defaultdb?sslaccept=strict"
#
# Quick local test without a CA certificate. This still uses SSL, but it does
# not strictly verify the server certificate, so do not use it for production:
# DATABASE_URL="mysql://avnadmin:YOUR_AIVEN_PASSWORD@mysql-39c4cc2d-haroonzahid644-be2b.k.aivencloud.com:12673/defaultdb?sslaccept=accept_invalid_certs"
#
# If Prisma/Windows gives a certificate verification error, download the
# Aiven CA certificate, save it as backend/certs/aiven-ca.pem, and use:
# DATABASE_URL="mysql://avnadmin:YOUR_AIVEN_PASSWORD@mysql-39c4cc2d-haroonzahid644-be2b.k.aivencloud.com:12673/defaultdb?sslaccept=strict&sslcert=./certs/aiven-ca.pem"
