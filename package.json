{
  "name": "bookme-pk",
  "private": true,
  "workspaces": [
    "backend",
    "frontend-admin"
  ],
  "description": "Root-level database and global configuration tooling for Bookme.pk.",
  "scripts": {
    "prisma:generate": "node -r ./global/env ./node_modules/prisma/build/index.js generate --schema ./database/schema.prisma",
    "prisma:migrate": "node -r ./global/env ./node_modules/prisma/build/index.js migrate dev --schema ./database/schema.prisma",
    "prisma:studio": "node -r ./global/env ./node_modules/prisma/build/index.js studio --schema ./database/schema.prisma",
    "prisma:seed": "node ./database/seed.js"
  },
  "prisma": {
    "seed": "node ./database/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "apexcharts": "^5.16.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.6.1",
    "echarts": "^6.1.0",
    "node-cron": "^4.6.0",
    "vue-echarts": "^8.0.1",
    "vue3-apexcharts": "^1.11.1"
  },
  "devDependencies": {
    "prisma": "^6.19.3"
  },
  "version": "1.0.0",
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Izma-Nabi/HR_Management_System.git"
  },
  "keywords": [],
