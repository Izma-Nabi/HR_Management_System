generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum EmploymentStatus {
  ACTIVE
  INACTIVE
  RESIGNED
  TERMINATED
}

enum AttendanceStatus {
  Present
  Absent
  Late
  Leave
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum LeaveApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeaveAction {
  APPROVED
  REJECTED
  CANCELLED
}

enum LeaveRequestType {
  ANNUAL
  CASUAL
  SICK
  UNPAID
  OTHER
}

model Role {
  id       Int    @id @default(autoincrement()) @db.UnsignedInt
  roleName String @unique @map("role_name") @db.VarChar(50)

  users           User[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id             Int    @id @default(autoincrement()) @db.UnsignedInt
  permissionName String @unique @map("permission_name") @db.VarChar(100)

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       Int @map("role_id") @db.UnsignedInt
  permissionId Int @map("permission_id") @db.UnsignedInt

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id Int @id @default(autoincrement()) @db.UnsignedInt

  userCode String? @unique @map("userCode") @db.VarChar(20)

  firstName String @map("firstName") @db.VarChar(100)
  lastName  String @map("lastName") @db.VarChar(100)

  email        String @unique @db.VarChar(255)
  passwordHash String @map("password_hash") @db.VarChar(255)

  phone       String? @db.VarChar(20)
  address     String? @db.VarChar(255)
  photo       String? @db.VarChar(255)
  designation String? @db.VarChar(100)

  joiningDate DateTime? @map("joiningDate") @db.Date

  employmentStatus EmploymentStatus @default(ACTIVE) @map("employmentStatus")

  roleId Int @map("role_id") @db.UnsignedInt
  role   Role @relation(fields: [roleId], references: [id])

  // User belongs to one department
  departmentId Int? @map("department_id") @db.UnsignedInt
  department   Department? @relation(fields: [departmentId], references: [id])

  // Admin manages many departments
  adminDepartments AdminDepartment[]

  // leaves 
  leaveRequests LeaveRequest[] @relation("LeaveRequester")

  currentLeaveApprovals LeaveRequest[] @relation("CurrentLeaveApprover")

  leaveApprovals LeaveApproval[] @relation("LeaveApprovalRefersTo")

  leaveApprovalHistory LeaveApprovalHistory[] @relation("LeaveHistoryRefersTo")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  @@index([roleId])
  @@index([departmentId])
  @@map("users")
}

model Department {
  id Int @id @default(autoincrement()) @db.UnsignedInt

  departmentName String @unique @map("department_name") @db.VarChar(100)
  description    String? @db.VarChar(255)

  // Users belonging to this department
  users User[]

  // Admins managing this department
  adminDepartments AdminDepartment[]

  @@map("departments")
}

model AdminDepartment {
  id Int @id @default(autoincrement()) @db.UnsignedInt

  userId       Int @map("user_id") @db.UnsignedInt
  departmentId Int @map("department_id") @db.UnsignedInt

  user       User @relation(fields: [userId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([userId, departmentId])
  @@index([userId])
  @@index([departmentId])

  @@map("admin_departments")
}

model Attendance {
  id               Int              @id @default(autoincrement()) @db.UnsignedInt
  userCode         String           @map("user_code") @db.VarChar(50)
  fullName         String           @map("full_name") @db.VarChar(100)
  role             String           @db.VarChar(50)
  department       String           @db.VarChar(100)
  attendanceDate   DateTime         @map("attendance_date") @db.Date
  checkIn          DateTime?        @map("check_in") @db.Time(0)
  checkOut         DateTime?        @map("check_out") @db.Time(0)
  status           AttendanceStatus
  remarks          String?          @db.Text
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  @@map("attendance")
}

model LeaveRequest {

  id Int @id @default(autoincrement()) @db.UnsignedInt

  userId Int @map("user_id") @db.UnsignedInt
  user User
    @relation("LeaveRequester", fields: [userId], references: [id], onDelete: Cascade)

  type LeaveRequestType

  startDate DateTime @map("start_date") @db.Date
  endDate DateTime @map("end_date") @db.Date

  totalDays Int @map("total_days")

  reason String? @db.Text

  status LeaveRequestStatus @default(PENDING)

  currentApprovalLevel Int
    @default(1)
    @map("current_approval_level")

  currentRefersTo Int?
    @map("current_refers_to")
    @db.UnsignedInt

  currentApprover User?
    @relation(
      "CurrentLeaveApprover",
      fields: [currentRefersTo],
      references: [id],
      onDelete: SetNull
    )

  approvals LeaveApproval[]

  history LeaveApprovalHistory[]

  createdAt DateTime
    @default(now())
    @map("created_at")

  updatedAt DateTime
    @updatedAt
    @map("updated_at")

  @@index([userId])
  @@index([currentRefersTo])
  @@index([status])
  @@map("leave_requests")
}

model LeaveApproval {

  id Int @id @default(autoincrement()) @db.UnsignedInt

  leaveRequestId Int
    @map("leave_request_id")
    @db.UnsignedInt

  leaveRequest LeaveRequest
    @relation(fields: [leaveRequestId], references: [id], onDelete: Cascade)

  refersTo Int
    @map("refers_to")
    @db.UnsignedInt

  approver User
    @relation(
      "LeaveApprovalRefersTo",
      fields: [refersTo],
      references: [id]
    )

  approvalLevel Int
    @map("approval_level")

  status LeaveApprovalStatus
    @default(PENDING)

  decisionNote String?
    @map("decision_note")
    @db.Text

  decidedAt DateTime?
    @map("decided_at")

  createdAt DateTime
    @default(now())
    @map("created_at")

  @@index([leaveRequestId])
  @@index([refersTo])
  @@index([status])

  @@map("leave_approvals")
}

model LeaveApprovalHistory {

  id Int @id @default(autoincrement()) @db.UnsignedInt

  leaveRequestId Int
    @map("leave_request_id")
    @db.UnsignedInt

  leaveRequest LeaveRequest
    @relation(fields: [leaveRequestId], references: [id], onDelete: Cascade)

  refersTo Int
    @map("refers_to")
    @db.UnsignedInt

  user User
    @relation(
      "LeaveHistoryRefersTo",
      fields: [refersTo],
      references: [id]
    )

  approvalLevel Int
    @map("approval_level")

  action LeaveAction

  remarks String?
    @db.Text

  createdAt DateTime
    @default(now())
    @map("created_at")

  @@index([leaveRequestId])
  @@index([refersTo])

  @@map("leave_approval_history")
}