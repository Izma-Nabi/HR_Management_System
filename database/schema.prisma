generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model Role {
  id        Int      @id @default(autoincrement()) @db.UnsignedInt
  roleName  String   @unique @map("role_name") @db.VarChar(50)

  users             User[]
  rolePermissions   RolePermission[]

  @@map("roles")
}

model Permission {
  id              Int      @id @default(autoincrement()) @db.UnsignedInt
  permissionName  String   @unique @map("permission_name") @db.VarChar(100)

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       Int @map("role_id") @db.UnsignedInt
  permissionId Int @map("permission_id") @db.UnsignedInt

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id           Int        @id @default(autoincrement()) @db.UnsignedInt
  fullName     String     @map("full_name") @db.VarChar(100)
  email        String     @unique @db.VarChar(255)
  passwordHash String     @map("password_hash") @db.VarChar(255)

  roleId       Int        @map("role_id") @db.UnsignedInt
  role         Role       @relation(fields: [roleId], references: [id])

  status       UserStatus @default(ACTIVE)

  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  adminProfile    AdminProfile?
  employeeProfile EmployeeProfile?

  @@index([roleId])
  @@index([status])
  @@map("users")
}

model Department {
  id              Int      @id @default(autoincrement()) @db.UnsignedInt
  departmentName  String   @unique @map("department_name") @db.VarChar(100)
  description     String?  @db.VarChar(255)

  admins          AdminProfile[]
  employees       EmployeeProfile[]

  @@map("departments")
}

model AdminProfile {
  id               Int         @id @default(autoincrement()) @db.UnsignedInt
  userId           Int         @unique @map("user_id") @db.UnsignedInt
  adminCode        String      @unique @map("admin_code") @db.VarChar(20)
  firstName        String      @map("first_name") @db.VarChar(100)
  lastName         String?     @map("last_name") @db.VarChar(100)
  phone            String?     @db.VarChar(30)
  address          String?     @db.VarChar(255)
  departmentId     Int?        @map("department_id") @db.UnsignedInt
  designation      String?     @db.VarChar(100)
  employmentStatus String?     @default("Active") @map("employment_status") @db.VarChar(50)
  joiningDate      DateTime?   @map("joining_date") @db.Date
  photo            String?     @db.VarChar(255)
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  @@index([departmentId])
  @@map("admin_profiles")
}

model EmployeeProfile {
  id           Int       @id @default(autoincrement()) @db.UnsignedInt
  userId       Int       @unique(map: "employee_profiles_user_id_unique") @map("user_id") @db.UnsignedInt
  employeeCode String    @unique(map: "employee_profiles_employee_code_unique") @map("employee_code") @db.VarChar(50)
  firstName    String    @map("first_name") @db.VarChar(100)
  lastName     String    @map("last_name") @db.VarChar(100)
  phone        String?   @db.VarChar(30)
  address      String?   @db.VarChar(255)
  photo        String?   @db.VarChar(255)
  departmentId Int?      @map("department_id") @db.UnsignedInt
  designation  String?   @db.VarChar(100)
  joiningDate  DateTime? @map("joining_date") @db.Date
  createdAt    DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade, map: "employee_profiles_user_id_fk")
  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  @@index([departmentId])
  @@map("employee_profiles")
}
