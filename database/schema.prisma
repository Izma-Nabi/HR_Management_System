generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum EmploymentStatus {
  ACTIVE
  INACTIVE
  RESIGNED
  TERMINATED
}

model Role {
  id       Int    @id @default(autoincrement()) @db.UnsignedInt
  roleName String @unique @map("role_name") @db.VarChar(50)

  users           User[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id             Int    @id @default(autoincrement()) @db.UnsignedInt
  permissionName String @unique @map("permission_name") @db.VarChar(100)

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       Int @map("role_id") @db.UnsignedInt
  permissionId Int @map("permission_id") @db.UnsignedInt

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id Int @id @default(autoincrement()) @db.UnsignedInt

  userCode String? @unique @map("userCode") @db.VarChar(20)

  firstName String @map("firstName") @db.VarChar(100)
  lastName  String @map("lastName") @db.VarChar(100)

  email        String @unique @db.VarChar(255)
  passwordHash String @map("password_hash") @db.VarChar(255)

  phone       String? @db.VarChar(20)
  address     String? @db.VarChar(255)
  photo       String? @db.VarChar(255)
  designation String? @db.VarChar(100)

  joiningDate DateTime? @map("joiningDate") @db.Date

  employmentStatus EmploymentStatus @default(ACTIVE) @map("employmentStatus")
  status             UserStatus       @default(ACTIVE)

  roleId Int @map("role_id") @db.UnsignedInt
  role   Role @relation(fields: [roleId], references: [id])

  // User belongs to one department
  departmentId Int? @map("department_id") @db.UnsignedInt
  department   Department? @relation(fields: [departmentId], references: [id])

  // Admin manages many departments
  adminDepartments AdminDepartment[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  @@index([roleId])
  @@index([departmentId])
  @@index([status])

  @@map("users")
}

model Department {
  id Int @id @default(autoincrement()) @db.UnsignedInt

  departmentName String @unique @map("department_name") @db.VarChar(100)
  description    String? @db.VarChar(255)

  // Users belonging to this department
  users User[]

  // Admins managing this department
  adminDepartments AdminDepartment[]

  @@map("departments")
}

model AdminDepartment {
  id Int @id @default(autoincrement()) @db.UnsignedInt

  userId       Int @map("user_id") @db.UnsignedInt
  departmentId Int @map("department_id") @db.UnsignedInt

  user       User @relation(fields: [userId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([userId, departmentId])
  @@index([userId])
  @@index([departmentId])

  @@map("admin_departments")
}